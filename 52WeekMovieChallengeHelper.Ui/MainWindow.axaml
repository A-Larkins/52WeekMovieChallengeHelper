<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MovieChallengeHelper.Ui.MainWindow"
        Title="52 Week Movie Challenge Helper"
        Width="620" Height="760"
        MinWidth="480" MinHeight="520"
        WindowStartupLocation="CenterScreen">

  <Window.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="Opacity" Value="0.6" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,0,16,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="TextBlock.value">
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
  </Window.Styles>

  <DockPanel Margin="24">

    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,20">
      <TextBlock Text="52 Week Movie Challenge Helper"
                 FontSize="22" FontWeight="SemiBold" />
      <TextBlock Text="Look up a film's credits, runtime and awards."
                 FontSize="13" Opacity="0.6" />
    </StackPanel>

    <!-- Search bar -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <TextBox Name="TitleBox"
               Grid.Column="0"
               Watermark="Enter a movie title…"
               FontSize="14"
               Margin="0,0,8,0" />
      <Button Name="SearchButton"
              Grid.Column="1"
              Content="Search"
              IsDefault="True"
              Padding="20,0"
              MinHeight="34"
              HorizontalContentAlignment="Center" />
    </Grid>

    <!-- Status line -->
    <TextBlock Name="StatusText"
               DockPanel.Dock="Top"
               Text=""
               TextWrapping="Wrap"
               FontSize="13"
               Margin="0,0,0,12"
               IsVisible="False" />

    <!-- Links (pinned to bottom) -->
    <StackPanel Name="LinksPanel"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,16,0,0"
                IsVisible="False">
      <Button Name="GoogleButton" Content="Oscars &amp; aspect ratio ↗" Padding="14,8" />
      <Button Name="QuotesButton" Content="IMDb quotes ↗" Padding="14,8" />
    </StackPanel>

    <!-- Results -->
    <Border Name="ResultsCard"
            BorderThickness="1"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            CornerRadius="8"
            Padding="20"
            IsVisible="False">
      <ScrollViewer>
        <Grid Name="FieldsGrid"
              ColumnDefinitions="130,*"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

          <TextBlock Grid.Row="0" Grid.Column="0" Classes="label" Text="Title" />
          <TextBlock Grid.Row="0" Grid.Column="1" Classes="value" Name="TitleValue" FontWeight="SemiBold" FontSize="15" />

          <TextBlock Grid.Row="1" Grid.Column="0" Classes="label" Text="Year released" Margin="0,10,16,0" />
          <TextBlock Grid.Row="1" Grid.Column="1" Classes="value" Name="YearValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="2" Grid.Column="0" Classes="label" Text="Run time" Margin="0,10,16,0" />
          <TextBlock Grid.Row="2" Grid.Column="1" Classes="value" Name="RunTimeValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="3" Grid.Column="0" Classes="label" Text="Genre" Margin="0,10,16,0" />
          <TextBlock Grid.Row="3" Grid.Column="1" Classes="value" Name="GenreValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="4" Grid.Column="0" Classes="label" Text="Rated" Margin="0,10,16,0" />
          <TextBlock Grid.Row="4" Grid.Column="1" Classes="value" Name="RatedValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="5" Grid.Column="0" Classes="label" Text="Starring" Margin="0,10,16,0" />
          <TextBlock Grid.Row="5" Grid.Column="1" Classes="value" Name="StarringValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="6" Grid.Column="0" Classes="label" Text="Directed by" Margin="0,10,16,0" />
          <TextBlock Grid.Row="6" Grid.Column="1" Classes="value" Name="DirectedByValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="7" Grid.Column="0" Classes="label" Text="Produced by" Margin="0,10,16,0" />
          <TextBlock Grid.Row="7" Grid.Column="1" Classes="value" Name="ProducedByValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="8" Grid.Column="0" Classes="label" Text="Written by" Margin="0,10,16,0" />
          <TextBlock Grid.Row="8" Grid.Column="1" Classes="value" Name="WrittenByValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="9" Grid.Column="0" Classes="label" Text="Music by" Margin="0,10,16,0" />
          <TextBlock Grid.Row="9" Grid.Column="1" Classes="value" Name="MusicByValue" Margin="0,10,0,0" />

          <TextBlock Grid.Row="10" Grid.Column="0" Classes="label" Text="Awards" Margin="0,10,16,0" />
          <TextBlock Grid.Row="10" Grid.Column="1" Classes="value" Name="AwardsValue" Margin="0,10,0,0" />

        </Grid>
      </ScrollViewer>
    </Border>

  </DockPanel>
</Window>
